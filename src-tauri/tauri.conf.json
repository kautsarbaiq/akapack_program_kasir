{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AKAPACK",
  "version": "0.1.0",
  "identifier": "com.akapack.pos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run tauri:export",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "AKAPACK",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "shortDescription": "POS & Manajemen Retail AKAPACK",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
